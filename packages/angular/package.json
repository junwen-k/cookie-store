{
  "name": "@cookie-store/angular",
  "description": "Reactive Cookie Store API binding for Angular.",
  "version": "0.1.0",
  "type": "module",
  "keywords": [
    "cookie",
    "cookie-store",
    "angular",
    "signals",
    "reactive",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "turbo watch build",
    "build": "tsup",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@cookie-store/core": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@cookie-store/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@angular/core": "^20.0.0"
  }
}
